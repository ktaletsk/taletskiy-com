{{- $pages := slice -}}
{{- range where .Site.RegularPages "Section" "blogs" -}}
  {{- if eq (.Param "newsletter") "jupyterlab-extensions" -}}
    {{- $pages = $pages | append . -}}
  {{- end -}}
{{- end -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/">
  <channel>
    <title>{{ .Title }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ with .Description }}{{ . }}{{ else }}{{ .Title }}{{ end }}</description>
    <generator>Hugo</generator>
    <language>{{ .Site.Language.LanguageCode }}</language>
    <atom:link href="{{ .Permalink }}" rel="self" type="application/rss+xml"></atom:link>
    {{- range $pages.ByDate.Reverse }}
    {{- $page := . -}}
    {{- $summary := cond (isset .Params "summary") .Params.summary (.Summary | plainify) -}}
    {{- $hero := cond (isset .Params "image") (.Params.image | absURL) "" -}}
    {{- $content := .Content
        | replaceRE `(?s)<iframe.*?</iframe>` ""
        | replaceRE `(?s)<script.*?</script>` ""
        | replaceRE `src="/` (printf "src=\"%s" .Site.BaseURL)
        | replaceRE `href="/` (printf "href=\"%s" .Site.BaseURL) -}}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      {{ printf "<description><![CDATA[<p>%s</p><p><a href=\"%s\">Read the full post on taletskiy.com</a></p>]]></description>" $summary .Permalink | safeHTML }}
      <content:encoded>{{ printf "<![CDATA[%s%s]]>"
        (cond (and (ne $hero "") (not (in $content $hero))) (printf "<p><img src=\"%s\" alt=\"%s\"></p>" $hero $page.Title) "")
        $content
        | safeHTML }}</content:encoded>
    </item>
    {{- end }}
  </channel>
</rss>
